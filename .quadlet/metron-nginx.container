[Unit]
Description=Metron Nginx Reverse Proxy
After=metron-web.service
Requires=metron-web.service

[Container]
Image=docker.io/library/nginx:alpine
ContainerName=metron-nginx
# Host networking gives nginx direct access to the host's network stack so
# real client IPs are visible rather than pasta's internal NAT address.
Network=host
LogDriver=journald
# nginx.conf: update this path to where the repo is cloned on the droplet
Volume=%h/metron/nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro,Z
# Let's Encrypt certs: see deployment notes in .quadlet/README.md
Volume=%h/.local/share/metron/letsencrypt:/etc/letsencrypt:ro,Z
Volume=%h/.local/share/metron/certbot-webroot:/var/www/certbot:ro,Z
Volume=/var/log/metron-nginx:/var/log/nginx
SecurityLabelDisable=true

[Service]
Restart=always

[Install]
WantedBy=default.target
